rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read and write only their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // TASKS: Production-Hardened ownership isolation
    match /tasks/{taskId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    
    // ANALYTICS: System-managed productivity intelligence
    match /productivity_stats/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Protected stats can only be mutated via administrative Cloud Functions
      allow write: if false; 
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
