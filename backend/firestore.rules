rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read and write only their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // TASKS: Only the owner can manage tasks
    match /tasks/{taskId} {
      allow read, write: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // ANALYTICS: Read-only for users (system-generated stats)
    match /productivity_stats/{statsId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Writing is restricted to Cloud Functions (Admin SDK) for production security
      allow write: if false; 
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
